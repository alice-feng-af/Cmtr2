module load STAR/2.7.10a

mkdir -p ~/star_index
gunzip -c ~/genome.fa.gz  > ~/genome.fa
gunzip -c ~/genome.gtf.gz > ~/genome.gtf
STAR --runThreadN 6 \
  --runMode genomeGenerate \
  --genomeDir ~/star_index \
  --genomeFastaFiles ~/genome.fa \
  --sjdbGTFfile ~/genome.gtf \
  --sjdbOverhang 99

mkdir -p ~/results/STAR
STAR --genomeDir ~/star_index \
  --runThreadN 1 \
  --readFilesIn ~/A***_1.fq.gz ~/A***_2.fq.gz \
  --readFilesCommand zcat \
  --outFileNamePrefix ~/results/STAR/A***_ \
  --outSAMtype BAM SortedByCoordinate

module load Qualimap/2.2.1
mkdir -p ~/results/qualimap
qualimap rnaseq \
  -bam ~/results/STAR/A***_Aligned.sortedByCoord.out.bam \
  -gtf ~/genome.gtf \
  -outdir ~/results/qualimap/A*** \
  -a proportional \
  -p non-strand-specific \
  --java-mem-size=16G
